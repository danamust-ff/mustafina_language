<Window x:Class="mustafina_language.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:mustafina_language"
        mc:Ignorable="d"
        Title="Mustafina" Height="450" Width="800"  Icon="/school_logo.ico" >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Языковая школа" Grid.Row="0" FontSize="30" HorizontalAlignment="Center"></TextBlock>
        <Image Source="/school_logo.png" HorizontalAlignment="Left"></Image>
        <Frame Grid.Row="1" Name="MainFrame"  ContentRendered="MainFrame_ContentRendered" NavigationUIVisibility="Hidden" ></Frame>
        <Button Content="BAck" Name="BtnBack"   HorizontalAlignment="Right"  Click="BtnBack_Click"   />
    </Grid>
</Window>
