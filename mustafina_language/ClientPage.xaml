<Page x:Class="mustafina_language.ClientPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:mustafina_language"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ClientPage"  FontFamily="Comic Sans MS" >

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>


        <WrapPanel HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Row="1">
            <TextBlock Text="Поиск: " FontSize="20"></TextBlock>
            <TextBox Name="TBox_Search" Height="30"  TextChanged="TBox_Search_TextChanged" Width="300" />
        </WrapPanel>
        <WrapPanel HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Column="1" Grid.Row="1" >
            <TextBlock Text="Пол: " FontSize="20"></TextBlock>
            <ComboBox Name="ComboGender"  Width="100" Height="30" SelectionChanged="ComboGender_SelectionChanged"  >
                <TextBlock>Все</TextBlock>
                <TextBlock>женский</TextBlock>
                <TextBlock>мужской</TextBlock>
            </ComboBox>

            <TextBlock Text="  Сортировка: " FontSize="20"></TextBlock>
            <ComboBox Name="ComboSort"  Width="198" Height="30" SelectionChanged="ComboSort_SelectionChanged" >
                <TextBlock>Нет</TextBlock>
                <TextBlock>От А до Я</TextBlock>
                <TextBlock>Дата последнего посещения</TextBlock>
                <TextBlock>Количество посещений</TextBlock>
            </ComboBox>
            <TextBlock Text="  "></TextBlock>
            <Button Name="BtnAdd" Content="Добавить клиента" Background="#FF03A0FA" Width="170" Click="BtnAdd_Click" Margin="5" Height="25"></Button>

        </WrapPanel>



        <ListView Name="ClientList"  Grid.Row="1" d:ItemsSource="{d:SampleData ItemCount=5}" >
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions> 
                        <Image Grid.Column="0" Grid.RowSpan="4" Stretch="UniformToFill" HorizontalAlignment="Center">
                            <Image.Source>
                                <Binding Path="PhotoPath"></Binding>
                            </Image.Source>
                        </Image>

                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" >
                            <TextBlock Text="ID: " FontSize="20"/>
                            <TextBlock Text="{Binding ID}" FontSize="20" />
                            <TextBlock Text=" " FontSize="20"/>
                            <TextBlock Text="{Binding LastName}" FontSize="20"/>
                            <TextBlock Text=" " FontSize="20"/>
                            <TextBlock Text="{Binding FirstName}" FontSize="20"/>
                            <TextBlock Text=" " FontSize="20"/>
                            <TextBlock Text="{Binding Patronymic}" FontSize="20"></TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="Пол: " FontSize="15"/>
                            <TextBlock Text="{Binding Gender.Name}" FontSize="15"/>
                            <TextBlock Text=" " FontSize="15"/>
                            <TextBlock Text="Дата рождения: " FontSize="15"/>
                            <TextBlock Text="{Binding Birthday, StringFormat={}{0:dd.MM.yyyy}}" FontSize="15"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="Телефон: " FontSize="15"/>
                            <TextBlock Text="{Binding Phone}" FontSize="15"/>
                            <TextBlock Text=" " FontSize="15"/>
                            <TextBlock Text="Почта: " FontSize="15"/>
                            <TextBlock Text="{Binding Email}" FontSize="15"/>
                        </StackPanel>
                        
                        
                        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="Дата добавления: " FontSize="15"/>

                            <TextBlock Text=" " FontSize="15"/>
                            <TextBlock Text="Кол-во посещений" FontSize="15"/>
                            
                        </StackPanel>
                        <Button Name="EditClient" Content="Редактировать" Grid.Column="2" Grid.Row="3" Background="#FF03A0FA"  Margin="0,12,0,15" Grid.RowSpan="2" Click="EditClient_Click"></Button>
                        <Button Name="DeleteClient" Content="Удалить" Grid.Column="3" Grid.Row="2" Background="#FF03A0FA" Click="DeleteClient_Click"></Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Grid.Row="3" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock Name="TBCount" FontSize="15" Height="30" ></TextBlock>
            <TextBlock Name="TBAllRecords" FontSize="15" Height="30" ></TextBlock>
            <TextBlock Text="  "></TextBlock>
            <TextBlock Text="Выводить по " FontSize="15" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"  ></TextBlock>
            <ComboBox Name="ComboPage" Width="100" Height="30" SelectionChanged="ComboPage_SelectionChanged" Grid.Row="3"  Grid.Column="1"  HorizontalAlignment="Right" />
            <Button Name="LeftDirButton" Content="&lt;" Width="25" Height="25" Click="LeftDirButton_Click" Background="#FF03A0FA"/>
            <ListBox FontSize="20" Name="PageListBox" MouseUp="PageListBox_MouseUp">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
            <Button Name="RightDirButton" Content="&gt;" Width="25" Height="25" Click="RightDirButton_Click" Background="#FF03A0FA"/>
        </StackPanel>
    </Grid>
</Page>
