<Page x:Class="mustafina_language.ClientPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:mustafina_language"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ClientPage"  FontFamily="Comic Sans MS" >

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <ListView Name="ClientList"  Grid.Row="1" d:ItemsSource="{d:SampleData ItemCount=5}" >
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions> 
                        <Image Grid.Column="0" Grid.RowSpan="4" Stretch="UniformToFill" HorizontalAlignment="Center">
                            <Image.Source>
                                <Binding Path="PhotoPath"></Binding>
                            </Image.Source>
                        </Image>

                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" >
                            <TextBlock Text="ID: " FontSize="20"/>
                            <TextBlock Text="{Binding ID}" FontSize="20" />
                            <TextBlock Text=" " FontSize="20"/>
                            <TextBlock Text="{Binding LastName}" FontSize="20"/>
                            <TextBlock Text=" " FontSize="20"/>
                            <TextBlock Text="{Binding FirstName}" FontSize="20"/>
                            <TextBlock Text=" " FontSize="20"/>
                            <TextBlock Text="{Binding Patronymic}" FontSize="20"></TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="Пол: " FontSize="15"/>
                            <TextBlock Text="{Binding Gender.Name}" FontSize="15"/>
                            <TextBlock Text=" " FontSize="15"/>
                            <TextBlock Text="Дата рождения: " FontSize="15"/>
                            <TextBlock Text="{Binding Birthday, StringFormat={}{0:dd.MM.yyyy}}" FontSize="15"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="Телефон: " FontSize="15"/>
                            <TextBlock Text="{Binding Phone}" FontSize="15"/>
                            <TextBlock Text=" " FontSize="15"/>
                            <TextBlock Text="Почта: " FontSize="15"/>
                            <TextBlock Text="{Binding Email}" FontSize="15"/>
                        </StackPanel>
                        
                        
                        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="Дата добавления: " FontSize="15"/>

                            <TextBlock Text=" " FontSize="15"/>
                            <TextBlock Text="Кол-во посещений" FontSize="15"/>
                            
                        </StackPanel>
                        
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
       
        <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Name="LeftButton" Content="&lt;" Width="20" Height="20" Click="LeftButton_Click"  ></Button>
            <ListBox FontSize="20" Name="PageListBox" MouseUp="PageListBox_MouseUp" >
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
            <Button Name="RightButton" Content="&gt;" Width="20" Height="20" Click="RightButton_Click"  ></Button>
        </StackPanel>
    </Grid>
</Page>
